      <outline type="rss" text="Andrej Karpathy" title="Andrej Karpathy" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCXUPKJO5MZQN11PqgIvyuvQ" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCXUPKJO5MZQN11PqgIvyuvQ" description="" language="en_US" />
      <outline type="rss" text="Anthropic" title="Anthropic" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCrDwWp7EBBv4NwvScIpBDOA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCrDwWp7EBBv4NwvScIpBDOA" description="We’re an AI safety and research company. Talk to our AI assistant Claude on claude.com. Download Claude on desktop, iOS, or Android.   We believe AI will have a vast impact on the world. Anthropic is dedicated to building systems that people can rely on and generating research about the opportunities and risks of AI." language="en_US" />
      <outline type="rss" text="AssemblyAI" title="AssemblyAI" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCtatfZMf-8EkIwASXM4ts0A" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCtatfZMf-8EkIwASXM4ts0A" description="Welcome to the AssemblyAI YouTube channel, where we cover the latest innovations in AI and how to build AI-powered features fast." language="en_US" />
      <outline type="rss" text="Claude" title="Claude" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCV03SRZXJEz-hchIAogeJOg" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCV03SRZXJEz-hchIAogeJOg" description="The AI for problem solvers. Built by Anthropic to be safe, accurate, and secure. Talk to Claude on claude.ai or download the app on desktop &amp; mobile." language="en_US" />
      <outline type="rss" text="Cognitive Revolution" title="Cognitive Revolution" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCjNRVMBVI30Sak_p6HRWhIA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCjNRVMBVI30Sak_p6HRWhIA" description="The Cognitive Revolution is a podcast about AI where hosts Nathan Labenz and Erik Torenberg interview the builders on the edge of AI and explore the dramatic shift it will unlock over the next decades. " language="en_US" />
      <outline type="rss" text="DeepLearningAI" title="DeepLearningAI" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCcIXc5mJsHVYTZR1maL5l9w" htmlUrl="https://www.youtube.com" description="" language="en_US" />
      <outline type="rss" text="Every" title="Every" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCjIMtrzxYc0lblGhmOgC_CA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCjIMtrzxYc0lblGhmOgC_CA" description="The only subscription you need to stay at the edge of AI. Ideas, apps, and training: https://every.to" language="en_US" />
      <outline type="rss" text="Futurepedia" title="Futurepedia" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC_RovKmk0OCbuZjA8f08opw" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UC_RovKmk0OCbuZjA8f08opw" description="Learn to leverage AI tools and acquire AI skills to future-proof your life and business." language="en_US" />
      <outline type="rss" text="Google DeepMind" title="Google DeepMind" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCP7jMXSY2xbc3KCAE0MHQ-A" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCP7jMXSY2xbc3KCAE0MHQ-A" description="We live in an exciting time when AI research and technology are delivering extraordinary advances.In the coming years, AI — and ultimately artificial general intelligence (AGI) — has the potential to drive one of the greatest transformations in history." language="en_US" />
      <outline type="rss" text="How I AI" title="How I AI" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCRYY7IEbkHLH_ScJCu9eWDQ" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCRYY7IEbkHLH_ScJCu9eWDQ" description="How I AI, hosted by Claire Vo, is for anyone wondering how to actually use these magical new tools to improve the quality and efficiency of their work. In each episode, guests will share a specific, practical, and impactful way they’ve learned to use AI in their work or life. Expect 30-minute episodes, live screen sharing, and tips/tricks/workflows you can copy immediately. If you want to demystify AI and learn the skills you need to thrive in this new world, this podcast is for you." language="en_US" />
      <outline type="rss" text="Hung-yi Lee" title="Hung-yi Lee" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC2ggjtuuWvxrHHHiaDH1dlQ" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UC2ggjtuuWvxrHHHiaDH1dlQ" description="李宏毅" language="zh_CN" />
      <outline type="rss" text="LangChain" title="LangChain" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCC-lyoTfSrcJzA1ab3APAgw" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCC-lyoTfSrcJzA1ab3APAgw" description="Learn more about building LLM applications with LangChain" language="en_US" />
      <outline type="rss" text="Last Week in AI" title="Last Week in AI" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCKARTq-t5SPMzwtft8FWwnA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCKARTq-t5SPMzwtft8FWwnA" description="Weekly summaries of AI news!  Plus occasional articles, interviews, and more. Made by Skynet Today, a project by AI researchers and experts dedicated to providing accessible and informed coverage of the latest AI news and trends." language="en_US" />
      <outline type="rss" text="Liam Ottley" title="Liam Ottley" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCui4jxDaMb53Gdh-AZUTPAg" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCui4jxDaMb53Gdh-AZUTPAg" description="I’m an AI entrepreneur from New Zealand. In early 2023 I created the &apos;AI Automation Agency&apos; or &apos;AAA&apos; model based on my learnings at my own agency Morningside AI.  On this channel I share my learnings from running my own AI Automation Agency, AI SaaS and from helping my community of over 200,000 AI Automation Agency owners to start and scale their own AI business.  My mission is to inspire others to take advantage of the incredible AI opportunity by documenting my journey as an AI entrepreneur." language="en_US" />
      <outline type="rss" text="Machine Learning Street Talk" title="Machine Learning Street Talk" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCMLtBahI5DMrt0NPvDSoIRQ" htmlUrl="https://www.youtube.com" description="" language="en_US" />
      <outline type="rss" text="Matt Wolfe" title="Matt Wolfe" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UChpleBmo18P08aKCIgti38g" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UChpleBmo18P08aKCIgti38g" description="Exploring the capabilities of AI and the latest tech" language="en_US" />
      <outline type="rss" text="MattVidPro AI" title="MattVidPro AI" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC5Wz4fFacYuON6IKbhSa7Zw" htmlUrl="https://www.youtube.com" description="" language="en_US" />
      <outline type="rss" text="Matthew Berman" title="Matthew Berman" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCawZsQWqfGSbCI5yjkdVkTA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCawZsQWqfGSbCI5yjkdVkTA" description="Artificial Intelligence (AI), Open Source, Generative Art, AI Art, Futurism, ChatGPT, Large Language Models (LLM), Machine Learning, Technology, Coding, Tutorials, AI News, and more" language="en_US" />
      <outline type="rss" text="NetworkChuck" title="NetworkChuck" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC9x0AN7BWHpCDHSm9NiJFJQ" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UC9x0AN7BWHpCDHSm9NiJFJQ" description="I LOVE Information Technology!! My goal is to help as MANY PEOPLE AS POSSIBLE jump into a career in the IT field through obtaining IT Certifications. I talk about Cisco Certifications, CompTIA, AWS, Microsoft...pretty much EVERYTHING in IT. As a CBT Nuggets Trainer, it&apos;s also my passion to TEACH information technology and to make it FUN. " language="en_US" />
      <outline type="rss" text="Nick Saraev" title="Nick Saraev" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCbo-KbSjJDG6JWQ_MTZ_rNA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCbo-KbSjJDG6JWQ_MTZ_rNA" description="Hi 👋 I&apos;m Nick. I make money with AI tools like N8N, Claude Code, and Antigravity—and I teach others how they can too." language="en_US" />
      <outline type="rss" text="No Priors" title="No Priors" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCSI7h9hydQ40K5MJHnCrQvw" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCSI7h9hydQ40K5MJHnCrQvw" description="Your guide to the AI revolution, co-hosts Elad Gil and Sarah Guo talk to the world&apos;s leading engineers, researchers and founders about the biggest questions:" language="en_US" />
      <outline type="rss" text="OpenAI" title="OpenAI" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCXZCJLdBC09xxGZ6gcdrc6A" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCXZCJLdBC09xxGZ6gcdrc6A" description="OpenAI’s mission is to ensure that artificial general intelligence benefits all of humanity." language="en_US" />
      <outline type="rss" text="Pika Labs" title="Pika Labs" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC0SclYU4iiQRihtmDnak-gQ" htmlUrl="https://www.youtube.com" description="" language="en_US" />
      <outline type="rss" text="Riley Brown" title="Riley Brown" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCMcoud_ZW7cfxeIugBflSBw" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCMcoud_ZW7cfxeIugBflSBw" description="Vibe Coding AI Tools AI Automation AI Agents  These 5 categories of tools are changing the world.   On this channel, I dive into practical detail on how you can learn the most important technology our generation has ever seen.   My goal is to make advanced tools simple and accessible so anyone can create, launch, and win in this new era.   Subscribe if you&apos;re ready for a new vibe." language="en_US" />
      <outline type="rss" text="Runway" title="Runway" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCUBqu_z5uP0AZhYtuyFZB3g" htmlUrl="https://www.youtube.com" description="" language="en_US" />
      <outline type="rss" text="Siraj Raval" title="Siraj Raval" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCWN3xxRkmTPmbKwht9FuE5A" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCWN3xxRkmTPmbKwht9FuE5A" description="Hello World, it&apos;s Siraj!  I&apos;m a technologist on a mission to spread data literacy. Artificial Intelligence, Mathematics, Science, Technology, I simplify these topics to help you understand how they work. Using this knowledge you can build wealth and live a happier, more meaningful life. I live to serve this community. We are the fastest growing AI community in the world! " language="en_US" />
      <outline type="rss" text="Tao Prompts" title="Tao Prompts" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCc1qMq2UBJD9cSKbeBwGoZQ" htmlUrl="https://www.youtube.com" description="" language="en_US" />
      <outline type="rss" text="The AI Advantage" title="The AI Advantage" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCHhYXsLBEVVnbvsq57n1MTQ" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCHhYXsLBEVVnbvsq57n1MTQ" description="Practical AI Tutorials &amp; Weekly Updates You&apos;ll Actually Use" language="en_US" />
      <outline type="rss" text="Tina Huang" title="Tina Huang" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC2UXDak6o7rBm23k3Vv5dww" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UC2UXDak6o7rBm23k3Vv5dww" description="Hi! My name is Tina and I’m an ex-Meta data scientist.  This channel is about AI, coding, tech, career and self-study.  My goal is always to minimize effort and maximise outcome.  I basically refuse to do extra work to achieve my goals (which is why I love AI…)" language="en_US" />
      <outline type="rss" text="Two Minute Papers" title="Two Minute Papers" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCbfYPyITQ-7l4upoX8nvctg" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCbfYPyITQ-7l4upoX8nvctg" description="What a time to be alive!" language="en_US" />
      <outline type="rss" text="Unsupervised Learning: Redpoint&apos;s AI Podcast" title="Unsupervised Learning: Redpoint&apos;s AI Podcast" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCUl-s_Vp-Kkk_XVyDylNwLA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCUl-s_Vp-Kkk_XVyDylNwLA" description="On Unsupervised Learning we probe the sharpest minds in AI in search for the truth about what’s real today, what will be real in the future and what it all means for businesses and the world. If you’re a builder, researcher or investor navigating the AI world, this podcast will help you deconstruct and understand the most important breakthroughs and see a clearer picture of reality. Subscribe to this show to stay up to date on our latest episodes. " language="en_US" />
      <outline type="rss" text="Wes Roth" title="Wes Roth" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCqcbQf6yw5KzRoDDcZ_wBSw" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCqcbQf6yw5KzRoDDcZ_wBSw" description="Artificial Intelligence, AI, Machine Learning, Google DeepMind, OpenAI, ChatGPT, Anthropic, Tech, Coding, AI News, Large Language Models and... (most importantly)... optimism.   AGI rolls around only once. Let&apos;s make the best of it.  On this channel, my goal is to help everyone understand AI and it&apos;s implications better. To prepare for what&apos;s coming next.  The most important rule is &quot;Don&apos;t Panic&quot;.  The second rule is keep learning.  Thank you for joining me for this ride." language="en_US" />
      <outline type="rss" text="Yannic Kilcher" title="Yannic Kilcher" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCZHmQk67mSJgfCCTn7xBfew" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCZHmQk67mSJgfCCTn7xBfew" description="I make videos about machine learning research papers, programming, and issues of the AI community, and the broader impact of AI in society." language="en_US" />
      <outline type="rss" text="leerob" title="leerob" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCZMli3czZnd1uoc1ShTouQw" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCZMli3czZnd1uoc1ShTouQw" description="Building @Vercel" language="en_US" />
      <outline type="rss" text="跟李沐学AI" title="跟李沐学AI" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC8WCW6C3BWLKSZ5cMzD8Gyw" htmlUrl="https://www.youtube.com" description="" language="zh_CN" />
