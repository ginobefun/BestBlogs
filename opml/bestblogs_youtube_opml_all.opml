      <outline type="rss" text="EO" title="EO" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UClWTCPVi-AU9TeCN6FkGARg" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UClWTCPVi-AU9TeCN6FkGARg" description="EO Studio, a rapidly expanding global media platform, illuminates founders&apos; journeys through exceptional storytelling. We provide next-generation builders with innovative infrastructure and a rich resource network, empowering them to transform bold ideas into reality." language="en_US" />
      <outline type="rss" text="Google" title="Google" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCK8sQmJBp8GCxrOtXWBpyEA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCK8sQmJBp8GCxrOtXWBpyEA" description="Welcome to Google’s official YouTube channel — join us on our mission to organize the world’s information and make it universally accessible and useful. Subscribe to stay up-to-date on our latest product updates and innovation." language="en_US" />
      <outline type="rss" text="Greg Isenberg" title="Greg Isenberg" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCPjNBjflYl0-HQtUvOx0Ibw" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCPjNBjflYl0-HQtUvOx0Ibw" description="Subscribe for startup ideas &amp; tutorials on on how to use AI to build &amp; grow your startup.  Hey, I’m Greg - CEO of Late Checkout and ex-advisor to Reddit, TikTok, and more.  I post videos here from my podcast top 0.1% tech podcast called The Startup Ideas Podcast." language="en_US" />
