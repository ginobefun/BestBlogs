      <outline type="rss" text="The Pragmatic Engineer" title="The Pragmatic Engineer" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCPbwhExawYrn9xxI21TFfyw" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCPbwhExawYrn9xxI21TFfyw" description="Interviews about software engineering, Big Tech and startups. Highly relevant for developers and engineering leaders, useful for those working in tech." language="en_US" />
      <outline type="rss" text="Theo - t3․gg" title="Theo - t3․gg" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCbRP3c757lWg9M-U7TyEkXA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCbRP3c757lWg9M-U7TyEkXA" description="Software dev, AI nerd, TypeScript sympathizer, creator of T3 Chat and the T3 Stack." language="en_US" />
      <outline type="rss" text="Traversy Media" title="Traversy Media" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC29ju8bIPH5as8OGnQzwJyA" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UC29ju8bIPH5as8OGnQzwJyA" description="Traversy Media features the best online web development and programming tutorials for all of the latest web technologies from the building blocks of HTML, CSS &amp; JavaScript to frontend frameworks like React and Vue to backend technologies like Node.js, Python and PHP" language="en_US" />
      <outline type="rss" text="Web Dev Simplified" title="Web Dev Simplified" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCFbNIlppjAuEX4znoulh0Cw" htmlUrl="http://www.youtube.com/feeds/videos.xml?channel_id=UCFbNIlppjAuEX4znoulh0Cw" description="Web Dev Simplified is all about teaching web development skills and techniques in an efficient and practical manner. If you are just getting started in web development Web Dev Simplified has all the tools you need to learn the newest and most popular technologies to convert you from a no stack to full stack developer. Web Dev Simplified also deep dives into advanced topics using the latest best practices for you seasoned web developers." language="en_US" />
