{
  "name": "@bestblogs/cli",
  "version": "2.0.8",
  "description": "BestBlogs command-line interface — agent-friendly reading workflow (intake → discover → read → capture) backed by the /openapi/v2/* contract.",
  "bin": {
    "bestblogs": "dist/bestblogs.js",
    "bbcli": "dist/bestblogs.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin/bestblogs.ts",
    "test": "vitest run",
    "test:unit": "vitest run test/normalize.test.ts test/errors.test.ts",
    "test:e2e": "vitest run test/smoke.e2e.ts",
    "test:release": "pnpm test:unit && pnpm test:e2e",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "zod": "^3.23.8",
    "ofetch": "^1.3.4",
    "conf": "^13.0.1",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "keywords": [
    "bestblogs",
    "cli",
    "agent",
    "openapi",
    "reading",
    "ai"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "Gino <hi@bestblogs.dev>",
  "license": "MIT",
  "homepage": "https://bestblogs.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ginobefun/bestblogs-monorepo.git",
    "directory": "bestblogs-cli"
  }
}
